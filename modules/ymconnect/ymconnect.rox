import sys
ymlib = sys.loadlib('./libYMConnect.so')


type CoordinateType enum:
  Pulse = 0
  BaseCoordinate = 16
  RobotCoordinate
  ToolCoordinate = 18
  UserCoordinate = 19
  MasterTool = 20
  Undefined = 55
  JointDegrees = 56


type ControlGroupId enum:
    R1 = 1, R2, R3, R4, R5, R6, R7, R8
    B1 = 11, B2, B3, B4, B5, B6, B7, B8
    S1 = 21, S2, S3, S4, S5, S6, S7, S8, S9, S10, S11, S12, S13, S14, S15, S16, S17, S18, S19, S20, S21, S22, S23, S24



type SystemInfoId enum:
    R1 = 11, R2, R3, R4, R5, R6, R7, R8
    S1 = 21, S2, S3, S4, S5, S6, S7, S8, S9, S10, S11, S12, S13, S14, S15, S16, S17, S18, S19, S20, S21, S22, S23, S24
    A1 = 101, A2, A3, A4, A5, A6, A7, A8


type TimeType enum:
    ControllerOnTime = 1
    ServoPowerOnTimeTotal = 10
    ServoPowerOnTimeRobot = 11
    ServoPowerOnTimeStation = 20
    PlayBackTimeTotal = 110
    PlayBackTimeRobot = 111
    PlayBackTimeStation = 120
    MovingTimeTotal = 210
    MovingTimeRobot = 211
    MovingTimeStation = 221
    ApplicationOperationTime = 300


type ApplicationNumber enum:
    ApplicationOne = 1
    ApplicationTwo
    ApplicationThree
    ApplicationFour
    ApplicationFive
    ApplicationSix
    ApplicationSeven
    ApplicationEight


type SystemParameterType enum:
    S1CG = 0     // S1CxG requires group number.
    S2C = 1      // S2C
    S3C = 2      // S3C
    S4C = 3      // S4C
    RS = 4       // RS
    AP = 5       // AxP   requires group number
    SE = 6       // SxE   requires group number


type IOType enum:
  GeneralInput = 0
  GeneralOutput
  ExternalInput
  NetworkInput
  ExternalOutput
  NetworkOutput
  SpecificInput
  SpecificOutput
  InterfacePanelInput
  AuxiliaryRelay
  RobotControlStatus
  PsuedoInput


type CycleMode enum:
  Step = 0
  Cycle
  Automatic

type MoveInterpolationType enum:
  NoneSelected
  MoveJoint
  MoveLinear
  MoveCircular


@cstruct
type status_info_t object:

  var StatusCode :int
  @ctype(ctype='char*')
  var Message :string


@cstruct
type motoman_controller_t object:

  @ctype(ctype='void*')
  var _motomanController


@cstruct
type string_variable_data_t object:

  @ctype(ctype='char*')
  var stringVariableData :string

  @ctype(ctype='uint16_t')
  var variableIndex :int


@cstruct
type byte_variable_data_t object:

  @ctype(ctype='uint8_t')
  var value :int

  @ctype(ctype='uint16_t')
  var variableIndex :int

@cstruct
type integer_variable_data_t object:

  @ctype(ctype='int16_t')
  var value :int

  @ctype(ctype='uint16_t')
  var variableIndex :int

@cstruct
type double_variable_int_data_t object:

  @ctype(ctype='int32_t')
  var value :int

  @ctype(ctype='uint16_t')
  var variableIndex :int

@cstruct
type real_variable_data_t object:

  @ctype(ctype='float')
  var value :real

  @ctype(ctype='uint16_t')
  var variableIndex :int


@cstruct
type figure_t object:

  @ctype(ctype='int32_t')
  var frontOrBack :int

  @ctype(ctype='int32_t')
  var upperOrLower :int

  @ctype(ctype='int32_t')
  var flipOrNoFlip :int

  @ctype(ctype='int32_t[8]')
  var axisAngles :list


@cstruct
type position_data_t object:

  @ctype(ctype='int32_t')
  var coordinateType :int

  @ctype(ctype='figure_t')
  var figure :figure_t

  @ctype(ctype='uint32_t')
  var toolNumber :int

  @ctype(ctype='uint32_t')
  var userCoordinateNumber :int

  @ctype(ctype='double[8]')
  var axisData :list


@cstruct
type position_variable_data_t object:

  @ctype(ctype='position_data_t')
  var positionData :position_data_t

  @ctype(ctype='uint16_t')
  var variableIndex :int

@cstruct
type axis_configuration_data_t object:

  @ctype(ctype='int8_t[8]')
  var axisConfigurationData :list

@cstruct
type position_error_data_t object:

  @ctype(ctype='int32_t[8]')
  var axisData :list


@cstruct
type torque_data_t object:

  @ctype(ctype='int32_t')
  var controlGroupId :ControlGroupId

  @ctype(ctype='int32_t[8]')
  var axisData :list



// Generic primitive-pointer wrappers for FFI out-params
@cstruct
type Int32Data object:

  @ctype(ctype='int32_t')
  var value :int

@cstruct
type ByteData object:

  @ctype(ctype='uint8_t')
  var value :byte

@cstruct
type UInt16Data object:

  @ctype(ctype='uint16_t')
  var value :int

@cstruct
type UInt32Data object:

  @ctype(ctype='uint32_t')
  var value :int


// Math-related cstructs
@cstruct
type xyz_vector_t object:

  @ctype(ctype='double')
  var X :real

  @ctype(ctype='double')
  var Y :real

  @ctype(ctype='double')
  var Z :real

@cstruct
type euler_matrix_t object:

  @ctype(ctype='double')
  var nx :real
  @ctype(ctype='double')
  var ny :real
  @ctype(ctype='double')
  var nz :real
  @ctype(ctype='double')
  var ox :real
  @ctype(ctype='double')
  var oy :real
  @ctype(ctype='double')
  var oz :real
  @ctype(ctype='double')
  var ax :real
  @ctype(ctype='double')
  var ay :real
  @ctype(ctype='double')
  var az :real
  @ctype(ctype='double')
  var px :real
  @ctype(ctype='double')
  var py :real
  @ctype(ctype='double')
  var pz :real

@cstruct
type coordinate_array_t object:

  @ctype(ctype='double[8]')
  var values :list

@cstruct
type Real64Data object:

  @ctype(ctype='double')
  var value :real



@cstruct
type elapsed_time_t object:

  @ctype(ctype='uint32_t')
  var Seconds :int

  @ctype(ctype='uint32_t')
  var Minutes :int

  @ctype(ctype='uint32_t')
  var Hours :int


@cstruct
type time_data_t object:

  // Note: Actually a C++ std::time_t, which may be a long int (which is 64bits on x86 64, but 32 bits on ARMv7 32)
  // So, we assume 64bits here and marshal into 2 ints (note int is signed)
  @ctype(ctype='uint32_t[2]')
  var startTime :list

  @ctype(ctype='elapsed_time_t')
  var elapsedTime :elapsed_time_t


@cstruct
type system_info_data_t object:

  @ctype(ctype='char*')
  var softwareVersion :string

  @ctype(ctype='char*')
  var modelName :string


@cstruct
type controller_state_data_t object:

  @ctype(ctype='int32_t')
  var cycleMode :int

  @ctype(ctype='bool')
  var isRunning :bool

  @ctype(ctype='int32_t')
  var controlMode :int

  @ctype(ctype='bool')
  var isInHold :bool

  @ctype(ctype='bool')
  var isAlarming :bool

  @ctype(ctype='bool')
  var isErroring :bool

  @ctype(ctype='bool')
  var isServoOn :bool


@cstruct
type job_data_t object:

  @ctype(ctype='char*')
  var jobName :string

  @ctype(ctype='uint32_t')
  var line :int

  @ctype(ctype='uint32_t')
  var stepNumber :int

  @ctype(ctype='double')
  var speedOverride :real


@cstruct
type job_stack_t object:

  @ctype(ctype='char*[12]')
  var JobNames :list


@cstruct
type ParamValue object:

  @ctype(ctype='int32_t')
  var value :int


@cfunc(lib=ymlib, args='const char* ip_address, status_info_t* status, int32_t receivePacketTimeout_ms, int32_t sendPacketRetries, bool loggingEnabled, const char* version', ret='motoman_controller_t')
func open_connection(ip_address :string, status :status_info_t, receivePacketTimeout_ms :int, sendPacketRetries :int, loggingEnabled :bool, version :string) -> motoman_controller_t:
  _

@cfunc(lib=ymlib, args='motoman_controller_t controller')
proc close_connection(controller :motoman_controller_t):
  _


