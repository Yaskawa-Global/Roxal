// test it

proc raiseIfNotOk(status :status_info_t, function_name :string = ''):
  if status is nil:
    raise ProgramException("{function_name} error: nil status")

  if status.StatusCode != 0:
    var code = status.StatusCode
    var msg = status.Message
    raise ProgramException("{function_name} error {code}: {msg}")


proc test(ip :string):

  // Open connection
  var status = status_info_t()
  var ver :string = '1.1.5'
  var controller = open_connection(ip,status,200,5,true,ver)
  raiseIfNotOk(status,'open_connection')

  // controller system info
  var systemInfoData = system_info_data_t()
  status = controller_state_interface_read_system_information(controller, SystemInfoId.R1, systemInfoData)
  raiseIfNotOk(status,'controller_state_interface_read_system_information')
  print("R1="+dict(systemInfoData))

  var controllerStateData = controller_state_data_t()
  status = controller_state_interface_read_state(controller, controllerStateData)
  raiseIfNotOk(status,'controller_state_interface_read_state')
  print(dict(controllerStateData))

  var timeData = time_data_t()
  timeData.elapsedTime = elapsed_time_t()
  status = controller_state_interface_read_operating_times(controller, ControlGroupId.R1, TimeType.ControllerOnTime, timeData, ApplicationNumber.ApplicationOne)
  raiseIfNotOk(status,'controller_state_interface_read_operating_times')
  print(dict(timeData)|dict(timeData.elapsedTime))

  // control groups
  var axis_configuration = axis_configuration_data_t()
  status = control_group_interface_read_axis_configuration(controller,ControlGroupId.R1,axis_configuration)
  raiseIfNotOk(status,'control_group_interface_read_axis_configuration')
  var axis_config = axis_configuration.axisConfigurationData
  print("R1 axis config: {axis_config}")


  var pos_data = position_data_t()
  pos_data.figure = figure_t()
  status = control_group_interface_read_position_data(controller, ControlGroupId.R1,CoordinateType.RobotCoordinate,
                                                      1,0, pos_data)
  raiseIfNotOk(status,'control_group_interface_read_position_data')
  var pdata_dict = dict(pos_data)
  var pdata_fig = dict(pos_data.figure)
  print("pos_data= {pdata_dict} figure={pdata_fig}")


  // B var read
  var bvar_info = byte_variable_data_t()
  status = byte_variable_interface_read(controller,2,bvar_info)
  raiseIfNotOk(status,'byte_variable_interface_read')
  print("B2="+bvar_info.value)

  // I var read
  var ivar_info = integer_variable_data_t()
  //ivar_info.variableIndex = 2
  //ivar_info.value = 1001
  //integer_variable_interface_write(controller, ivar_info)
  status = integer_variable_interface_read(controller,2,ivar_info)
  raiseIfNotOk(status,'integer_variable_interface_read')
  print("I2="+ivar_info.value)

  // D var read
  var dvar_info = double_variable_int_data_t()
  status = double_int_variable_interface_read(controller,2,dvar_info)
  raiseIfNotOk(status,'double_int_variable_interface_read')
  print("D2="+dvar_info.value)

  // R var read
  var rvar_info = real_variable_data_t()
  status = real_variable_interface_read(controller,2,rvar_info)
  raiseIfNotOk(status,'real_variable_interface_read')
  print("R2="+rvar_info.value)

  // S var read/write
  var svar_info  = string_variable_data_t()
  status = string_variable_interface_read(controller,14,svar_info)
  raiseIfNotOk(status,'string_variable_interface_read')
  print("S14="+svar_info.stringVariableData)

  svar_info.variableIndex = 16
  svar_info.stringVariableData = 'fromroxal'
  status = string_variable_interface_write(controller, svar_info)
  raiseIfNotOk(status,'string_variable_interface_write')
  // read it back to check
  var svar_info2  = string_variable_data_t()
  status = string_variable_interface_read(controller,16,svar_info2)
  raiseIfNotOk(status,'string_variable_interface_read')
  if svar_info2.stringVariableData != svar_info.stringVariableData or svar_info2.variableIndex != 16:
    raise ProgramException("read back S16 didn't contain written content")

  // P var read/write
  var pvar_data = position_variable_data_t()
  pvar_data.positionData = position_data_t()
  pvar_data.positionData.figure = figure_t()
  status = robot_position_variable_interface_read(controller,10,pvar_data)
  raiseIfNotOk(status,'robot_position_variable_interface_read')
  if pvar_data.variableIndex != 10:
    raise ProgramException("read back P10 didn't contain the right index")
  print("Variable P10: "+dict(pvar_data)+" "+dict(pvar_data.positionData))


  // Param
  var paramValue = ParamValue()
  status = controller_state_read_system_param(controller, SystemParameterType.S2C,210,paramValue)
  raiseIfNotOk(status,'controller_state_read_system_param')
  var s2c210 = paramValue.value
  print("S2C210={s2c210}")


  // I/O
  var iobit = Int32Data()
  status = io_interface_type_ReadBit(controller, IOType.GeneralInput, 1, 4, iobit)
  raiseIfNotOk(status,'io_interface_type_ReadBit')
  var iobitData = dict(iobit)
  print("GeneralInput 1 bit 4 = {iobitData}")


  close_connection(controller)

test(ip='10.7.3.41')
