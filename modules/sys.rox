@builtin
func loadlib(path:string):
  """load a native library at path"""

func filter(items: const list, predicate) -> list:
  """return a new list containing elements for which predicate(element) returns true; predicate can optionally take (element, index)"""
  var result = []
  var arity = _arity(predicate)
  var i = 0
  for item in items:
    if arity >= 2:
      if predicate(item, i):
        result.append(item)
    else:
      if predicate(item):
        result.append(item)
    i = i + 1
  return result

func map(items: const list, transform) -> list:
  """return a new list with transform(element) applied to each element; transform can optionally take (element, index)"""
  var result = []
  var arity = _arity(transform)
  var i = 0
  for item in items:
    if arity >= 2:
      result.append(transform(item, i))
    else:
      result.append(transform(item))
    i = i + 1
  return result

func reduce(items: const list, reducer, initial):
  """reduce items to a single value by calling reducer(accumulator, element) for each element; reducer can optionally take (accumulator, element, index)"""
  var acc = initial
  var arity = _arity(reducer)
  var i = 0
  for item in items:
    if arity >= 3:
      acc = reducer(acc, item, i)
    else:
      acc = reducer(acc, item)
    i = i + 1
  return acc

