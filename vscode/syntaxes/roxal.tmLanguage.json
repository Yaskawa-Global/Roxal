{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Roxal",
  "scopeName": "source.roxal",
  "fileTypes": ["rox"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "annotations": {
      "name": "storage.modifier.annotation.roxal",
      "match": "@[_$A-Za-z][\\w$]*"
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.roxal",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.roxal",
          "match": "//.*$"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.roxal",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.nil.roxal",
          "match": "\\bnil\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.roxal",
          "match": "\\b(?:func|proc)\\s+([_$A-Za-z][\\w$]*)",
          "captures": {
            "1": { "name": "entity.name.function.roxal" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.roxal",
          "match": "\\b(?:if|else|elseif|while|for|break|continue|match|case|default|try|except|finally|raise|return|until|when|becomes|changes|occurs|where|emit|scope|with)\\b"
        },
        {
          "name": "keyword.control.import.roxal",
          "match": "\\bimport\\b"
        },
        {
          "name": "storage.type.modifier.roxal",
          "match": "\\b(?:var|const|mutable|private|implicit|func|proc|type|enum|event|operator|loperator|roperator)\\b"
        },
        {
          "name": "storage.type.class.roxal",
          "match": "\\b(?:object|actor|interface)\\b"
        },
        {
          "name": "keyword.other.roxal",
          "match": "\\b(?:implements|extends|as|by|in)\\b"
        },
        {
          "name": "variable.language.special.roxal",
          "match": "\\b(?:this|super)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.roxal",
          "match": "\\b(?:[0-9]+\\.[0-9]*|[0-9]*\\.[0-9]+)(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.float.roxal",
          "match": "\\b[0-9]+(?:[eE][+-]?[0-9]+)\\b"
        },
        {
          "name": "constant.numeric.hex.roxal",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.octal.roxal",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.roxal",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.roxal",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.roxal",
          "match": "<-|\\u2190|="
        },
        {
          "name": "keyword.operator.comparison.roxal",
          "match": "==|!=|<>|<=|>=|<|>|\\u225F|\\u2260|\\u2264|\\u2A7D|\\u2265|\\u2A7E"
        },
        {
          "name": "keyword.operator.arrow.roxal",
          "match": "->|\\u2192"
        },
        {
          "name": "keyword.operator.range.roxal",
          "match": "\\.\\.(?:\\.|\\u2026)?"
        },
        {
          "name": "keyword.operator.logical.roxal",
          "match": "\\b(?:and|or|not|is)\\b"
        },
        {
          "name": "keyword.operator.arithmetic.roxal",
          "match": "[+\\-*/%\\u00D7]"
        },
        {
          "name": "keyword.operator.bitwise.roxal",
          "match": "[&|^~]"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.roxal",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string_escapes" }
          ]
        },
        {
          "name": "string.quoted.single.roxal",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "include": "#string_escapes" }
          ]
        },
        {
          "name": "string.quoted.double.roxal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string_escapes" }
          ]
        }
      ]
    },
    "string_escapes": {
      "name": "constant.character.escape.roxal",
      "match": "\\\\."
    },
    "types": {
      "name": "storage.type.roxal",
      "match": "\\b(?:bool|byte|number|int|real|decimal|string|range|enum|list|dict|vector|matrix|signal|tensor|orient|event|object|actor|interface)\\b"
    }
  }
}
