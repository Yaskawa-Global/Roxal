# ai.nn chaining test: pass tensor through two identity models
# and verify it stays on GPU between inferences (when CUDA available)
import ai.nn

var model_a = ai.nn.load("../modules/ai/identity-10.onnx")
var model_b = ai.nn.load("../modules/ai/identity-10.onnx")

# warmup (needed for CUDA context init)
var warmup = tensor(1, 10, dtype='float32')
model_a.run(warmup)
model_b.run(warmup)

# prepare input with known values
var input = tensor(1, 10, dtype='float32')
input[0, 0] = 1.0
input[0, 3] = 42.0
input[0, 7] = -3.5
input[0, 9] = 99.0

# remember the model's execution device
var dev = model_a.device()
print(dev == "cpu" or dev == "cuda")

# input is always on CPU (created by Roxal)
print(ai.nn.tensor_device(input))

# chain: model_a -> model_b
var mid = model_a.run(input)

# intermediate tensor must match the model's device:
# on GPU systems mid is on cuda (IoBinding), on CPU systems mid is on cpu
var mid_dev = ai.nn.tensor_device(mid)
print(mid_dev == dev)

var out = model_b.run(mid)
var out_dev = ai.nn.tensor_device(out)
print(out_dev == dev)

# verify values survived the chain (triggers ensureCpu if on GPU)
print(out[0, 0])
print(out[0, 3])
print(out[0, 7])
print(out[0, 9])

# after element access, tensor should be on CPU
print(ai.nn.tensor_device(out))

# cleanup
model_a.close()
model_b.close()
print("done")
