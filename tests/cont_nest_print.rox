// Bug: print() implicit param conversion + nested @builtin constructor
// nativeContinuation.active from outer param conversion causes
// callValue to skip instance restoration for the nested constructor

type Wrapper object:
  private var _span:TimeSpan

  proc init(s:int, us:int):
    _span = TimeSpan(seconds=s, micros=us)

  @implicit
  func operator string() -> string:
    var copy = TimeSpan(seconds=_span.seconds(), micros=_span.microseconds())
    return copy.human()

var w = Wrapper(2, 500000)
print(w)
