// Test: print() implicit param conversion with nested @builtin constructor
// Exercises continuation nesting: print's param conversion frame contains
// a @builtin constructor call (TimeSpan) that must complete correctly.

type Wrapper object:
  private var _span:TimeSpan

  proc init(s:int, us:int):
    _span = TimeSpan(seconds=s, micros=us)

  @implicit
  func operator string() -> string:
    var copy = TimeSpan(seconds=_span.seconds(), micros=_span.microseconds())
    return copy.human()

var w = Wrapper(2, 500000)
print(w)
