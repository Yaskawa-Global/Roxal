var e:event

func f():

  type MyObject object:

    proc amethod(i :int):

      on e:
        print('e occured within MyObject.amethod('+i+')')

      print('amethod '+i)


  return MyObject()


o = f()
o2 = f()

print('calling amethods')
o.amethod(1)
o2.amethod(2)

print('emitting e')
emit e()

wait(us=1000)

print('destroying o')
o = nil

wait(us=1000)

print('emitting e')
emit e()

wait(us=1000)

print('done')
