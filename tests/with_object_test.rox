// Test with statement with object instance

type Point object:
    var x :int
    var y :int

// Test basic with statement with object
var p = Point(x=10, y=20)
with p:
    print(x)
    print(y)
    x = 15
    print(x)

print(p.x)  // Should be 15 from the assignment inside with

// Test with statement inside function
func testWithInFunction():
    var p2 = Point(x=5, y=12)
    with p2:
        print("x={x}, y={y}")

testWithInFunction()

// Test nested with statements
type Rectangle object:
    var width :int
    var height :int

var r = Rectangle(width=100, height=50)
with r:
    print("Rectangle: {width}x{height}")
    var corner = Point(x=width, y=height)
    with corner:
        print("Corner at ({x}, {y})")
