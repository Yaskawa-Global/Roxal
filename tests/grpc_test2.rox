_import("route_guide.proto")

var req = Rectangle()
var resp = Feature()
var lo = Point()
var hi = Point()


lo.latitude = 400000000
lo.longitude = -750000000
hi.latitude = 420000000
hi.longitude = -730000000

req.lo = lo
req.hi = hi

resp = _FindFeature(req)

print(resp.name) //Expected PatriotsPath,Mendham,NJ07945,USA
print(resp.location.latitude) //Expected 407838351
print(resp.location.longitude) //Expected -746143763
