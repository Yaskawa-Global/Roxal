
type E event

type MyActor actor:

  proc setup():
    when E occurs:
      print('e handled in MyActor')


a = MyActor()

emit E()  // no handlers
wait(us=10000)

a.setup() // install hander
wait(us=10000)

emit E()  // should trigger the hander in setup()
wait(us=10000)

a = nil   // destruct actor, it's thread and the handler along with it
wait(us=20000)

emit E()  // nothing
wait(us=200)

print('done')
