
var e :event

type MyActor actor:

  proc setup():
    on e:
      print('e handled in MyActor')


a = MyActor()

emit e  // no handlers
sleep(us=10000)

a.setup() // install hander
sleep(us=10000)

emit e  // should trigger the hander in setup()
sleep(us=10000)

a = nil   // destruct actor, it's thread and the handler along with it
sleep(us=20000)

emit e  // nothing
sleep(us=200)

print('done')
