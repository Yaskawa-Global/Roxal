
var e :event

type MyActor actor:

  proc setup():
    on e:
      print('e handled in MyActor')


a = MyActor()

e.emit()  // no handlers

a.setup() // install hander
sleep(200)

e.emit()  // should trigger the hander in setup()
sleep(200)

a = nil   // destruct actor, it's thread and the handler along with it

e.emit()  // nothing
sleep(200)

print('done')
