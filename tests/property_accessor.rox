type Widget object:

    # Property with both getter and setter
    var width :int = 100:
        get:
            print("Getting width: {_width}")
            return _width
        set:
            print("Setting width to: {value}")
            _width = value

    # Read-only property (getter only)
    const height :int = 50:
        get:
            print("Getting height: {_height}")
            return _height

    # Write-only property (setter only)
    var depth :int = 25:
        set:
            print("Setting depth to: {value}")
            _depth = value

    # Property with computed getter
    var area :int = 0:
        get:
            var result = _width * _height
            print("Computing area: {result}")
            return result

    proc init():
        _

    proc test_internal_access():
        print('=== Internal access (from within methods) ===')

        # Using this. prefix
        print("\n1. Using this.width:")
        var w1 = this.width
        print("Got: {w1}")

        print("\n2. Setting this.width = 150:")
        this.width = 150

        # Using bare identifiers (no this. prefix)
        print("\n3. Using bare width (no this.):")
        var w2 = width
        print("Got: {w2}")

        print("\n4. Setting bare width = 200:")
        width = 200

        # Read-only property
        print("\n5. Reading height (read-only):")
        var h = height
        print("Got: {h}")

        # Write-only property
        print("\n6. Writing depth (write-only):")
        depth = 30

        # Computed property
        print("\n7. Reading computed area:")
        var a = area
        print("Got: {a}")

var widget = Widget()

print('=== Testing internal access ===')
widget.test_internal_access()

print('\n=== External access (from main) ===')

# Read/write property
print("\n1. External read widget.width:")
var ext_w = widget.width
print("Got: {ext_w}")

print("\n2. External write widget.width = 250:")
widget.width = 250

# Read-only property
print("\n3. External read widget.height (read-only):")
var ext_h = widget.height
print("Got: {ext_h}")

# Write-only property
print("\n4. External write widget.depth (write-only):")
widget.depth = 35

# Computed property
print("\n5. External read widget.area (computed):")
var ext_a = widget.area
print("Got: {ext_a}")

print('\n=== All property accessor tests passed! ===')
