type ReadOnly interface:
    const tag :string

type WithConstMember object implements ReadOnly:
    const tag :string = "fixed"

type WithVarMember object implements ReadOnly:
    var tag :string

type WithGetter object implements ReadOnly:
    const tag :string = "":
        get:
            return "got"

var a = WithConstMember()
print(a.tag)
print(a is ReadOnly)

var b = WithVarMember("v")
print(b.tag)
print(b is ReadOnly)

var c = WithGetter()
print(c.tag)
print(c is ReadOnly)
