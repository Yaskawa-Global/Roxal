// @implicit(nonstrict_only=true): implicit in non-strict, explicit in strict
type Tag object:
  var name = ''
  proc init(name):
    this.name = name
  @implicit(nonstrict_only=true)
  func operator string():
    return '<' + name + '>'

// Non-strict (module scope): implicit concat works
print("tag: " + Tag('hello'))

// Strict (function body): explicit works
func test():
  var t = Tag('world')
  print("explicit: " + string(t))

test()
