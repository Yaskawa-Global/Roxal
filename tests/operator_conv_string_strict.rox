# @implicit(nonstrict_only=true): implicit in non-strict, explicit required in strict
type Item object:
  var val = 0
  proc init(val):
    this.val = val
  @implicit(nonstrict_only=true)
  func operator string():
    return "Item(" + string(val) + ")"

func test(item):
  # Explicit conversion always works in strict context
  var s = string(item)
  print(s)

var i = Item(42)
# Module scope is non-strict, so implicit works with nonstrict_only
print("implicit: " + i)
# Explicit works everywhere
test(i)
