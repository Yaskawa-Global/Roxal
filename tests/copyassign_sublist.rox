var l = [1,2,3]
var l2 = [4,5,6]

l[1] = l2 // l is now [1,[4,5,6],3], but the element l[1] is l2 (same reference)

print(l[1] is l2) // true
print(l) 

var l4 = [4,4,4]
// hence, if we shallow copy assign l[1], it should behave like copy assigning any other list lvalue

l[1] <- l4  // just copy the values in l4 ([4,4,4]) into l[1] which is l2


print(l)  // [1,[4,4,4],3]
print(l[1] is l2) // should still be true
print(l2) // should now be [4,4,4]

