import sys

var wall = sys.Time()
print(wall.kind())
print(wall.isSteady())

var parsed = sys.Time.parse("2023-08-20 13:36:00.500000", "%Y-%m-%d %H:%M:%S.%f", tz='utc')
var components = parsed.components(tz='utc')
print(components['year'])
print(components['month'])
print(components['day'])
print(components['hour'])
print(components['minute'])
print(components['second'])
print(components['microsecond'])
print(components['weekday'])
print(components['yearday'])

print(parsed.format("%Y-%m-%d %H:%M:%S.%f", tz='utc'))

var earlier = sys.Time.parse("2023-08-19 12:34:56", "%Y-%m-%d %H:%M:%S", tz='utc')
var diff = parsed.diff(earlier)
print(diff.seconds())
print(diff.microseconds())
var split = diff.split()
print(split['days'])
print(split['hours'])
print(split['minutes'])
print(split['seconds'])
print(split['millis'])
print(split['micros'])
print(split['negative'])
print(diff.total_hours())
print(diff.human())

var span = sys.TimeSpan.from_fields(days=1, hours=2, minutes=3, seconds=4, millis=5, micros=6)
var spanSplit = span.split()
print(spanSplit['days'])
print(spanSplit['hours'])
print(span.total_seconds())
print(span.total_micros())
print(span.human())

var steady = sys.Time.steady_now()
print(steady.isSteady())
var steadyDiff = steady.diff(steady)
print(steadyDiff.total_micros())
