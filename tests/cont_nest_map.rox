// Test: list.map callback constructs @builtin object
// Exercises continuation nesting: map's callback body calls a @builtin constructor.

var durations = [1, 2, 3]
var spans = durations.map(func(d):
  return TimeSpan(seconds=d)
)
print(spans[0].total_seconds())
print(spans[1].total_seconds())
print(spans[2].total_seconds())
