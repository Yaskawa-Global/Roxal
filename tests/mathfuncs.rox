import math
print(math.sqrt(9))
print(math.pow(2,5))
print(math.floor(1.9))
print(math.ceil(1.1))
print(math.fmod(5.5,2))
print(math.trunc(3.8))
print(math.round(2.3))
print(math.log10(1000))
print(math.hypot(3,4))
print(math.copysign(2,-5))
print(math.erf(0.5))
print(math.erfc(0.5))
print(math.exp2(5))
print(math.expm1(1))
print(math.fdim(5,3))
print(math.lgamma(1))
print(math.log1p(1))
print(math.logb(16))
print(math.nearbyint(2.7))
print(math.nextafter(1,2))
print(math.rint(2.3))
print(math.tgamma(5))

