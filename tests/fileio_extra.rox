import fileio

print(fileio.file_exists('../tests/testfile.txt'))
print(fileio.dir_exists('../tests'))
print(fileio.file_size('../tests/testfile.txt'))
var abs = fileio.absolute_file_path('../tests/testfile.txt')
print(fileio.path_file(abs))
print(fileio.path_directory('folder/sub/file.ext'))
print(fileio.file_extension('folder/file.ext'))
print(fileio.file_without_extension('folder/file.ext'))
