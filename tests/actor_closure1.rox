
type A actor:
  private var secret = [1, 2]
  func printSecret():
    print(secret)
  func makeGetter():
    var local = secret
    func getter():
      return local // captures local (list ref)
    return getter  // returns from actor methods are cloned

print('creating actor instance')
var a = A()
ignore(a.printSecret())

print('exfiltrating secret')
var getter = a.makeGetter()
var lst = getter()  // lst was cloned from secret

print('mutating secret')
lst[0] = 55  // really just mutating clone of secret
print(lst)

print('asking actor to print secret')
ignore(a.printSecret()) // should print [1,2]

wait(ms=100)

print('done')
