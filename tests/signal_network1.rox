
var c :signal = clock(10)

var v :vector = [1 2 3 4 5 6]

// split vector into list of its elements
func split(v :vector) -> list:
  var l :list
  for e in v:
    l.append(e)
  return l

// join a list of values into a vector
func join(l :list) -> vector:
  return vector(l)

func addToElt0(v :vector, i: int) -> vector:
  var newV = vector(v)  // Create a copy to avoid in-place modification
  newV[0] = newV[0] + i
  return newV

[out0, out1, out2, out3, out4, out5] = split(addToElt0(v,c))

//out = join([out0, out1, out2, out3, out4, out5])

c.tick()
_ussleep(110000)

print(out0)


