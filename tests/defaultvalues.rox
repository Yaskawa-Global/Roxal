// check default initialized values

var b :bool
var bt :byte
var i :int
var r: real
//var d :decimal
var s :string
var ra: range
var l :list
var d :dict
var v: vector

print(b)  // false
print(bt) // 0
print(i)  // 0
print(r)  // 0
//print(d)  // 0
print(s)  // nothing
print(ra) // 0..<0
print(l)  // []
print(d)  // {}
print(v)  // []
print(len(v)) // 0
