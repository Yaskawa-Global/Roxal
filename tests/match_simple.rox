# Simpler match test

func test1(x: int) -> str:
    match x:
        case 1:
            return "one"
        default:
            return "other"

print("Test with 1: " + test1(1))
print("Test with 2: " + test1(2))

func test2(x: int) -> str:
    match x:
        case 1:
            return "one"
        case 2:
            return "two"
        default:
            return "other"

print("Test 2 with 1: " + test2(1))
print("Test 2 with 2: " + test2(2))
print("Test 2 with 3: " + test2(3))

func test3(x: int) -> str:
    match x:
        case 3:
            return "three"
        default:
            return "other"

print("Test 3 with 3: " + test3(3))
print("Test 3 with 1: " + test3(1))
