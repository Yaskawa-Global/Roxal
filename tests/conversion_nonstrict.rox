# Non-strict conversions using explicit constructors and implicit assignments
var b = true
print(int(b))
print(real(b))
print(string(b))

var i = 260
print(real(i))
print(string(i))

var r = 3.7
print(string(r))
print(int(r))

var s = "123"
print(int(s))
print(real("5.5"))

# enum conversions
type E enum:
  A
  B=3
  C

var e = E.B
print(int(e))
print(string(e))

# byte conversions
var by = byte(255)
print(int(by))
print(real(by))
print(string(by))

var i2: int
i2 = byte(1)
print(i2)

# decimal conversions
var d = decimal(3.14)
print(real(d))
print(string(d))

var r3: real
r3 = decimal(2.5)
print(r3)

var i3: int
i3 = decimal(2.5)
print(i3)
