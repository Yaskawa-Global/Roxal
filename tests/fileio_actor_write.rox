import fileio

var path = 'fileio_actor_write.log'
var line_count = 10

type Writer actor:
  func emit_lines(path, count) -> bool:
    var h = fileio.open(path, append=false, write=true)
    var i = 0
    while i < count:
      fileio.write(h, 'alpha ')
      fileio.write(h, 'beta ')
      fileio.write(h, string(i) + ' ')
      fileio.write(h, '\n')
      i = i + 1
    var done = fileio.close(h)
    wait(for=done)
    return bool(done)

var initializer = fileio.open(path, append=true)
wait(for=fileio.close(initializer))

var writer = Writer()
wait(for=writer.emit_lines(path, line_count))

var reader = fileio.open(path, append=false, format='binary')
var data = fileio.read(reader)
wait(for=fileio.close(reader))
print(data)
