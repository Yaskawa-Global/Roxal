// Auto-await: an actor func() at statement position now blocks (auto-awaits)
// instead of fire-and-forget. We make compute() print a message *after*
// its wait — so if the call blocks, that message appears BEFORE the
// post-statement print; if it didn't block, it would appear AFTER.

type W actor:
  func compute() -> int:
    wait(ms=50)
    print("compute-done")
    return 42
  proc tickProc():
    wait(ms=20)
    print("proc-side-effect")

w = W()

print("before")
// statement-position func call — must block, so "compute-done" prints first
w.compute()
print("after-func")

// proc remains fire-and-forget; "after-proc" prints before
// "proc-side-effect" (queued on the actor, runs after the wait below).
w.tickProc()
print("after-proc")

// Give the proc time to run before the test exits.
wait(ms=100)
