//
// clock 10Hz в”Җв”Җв–ә (+) в”Җв”Җв–ә (*2) в”Җв”Җв–ә out в”Җв”Җв–ә print
//                 в–І             в”Ӯ
//                 в”Ӯ             в”Ӯ
//                 в””в”Җв”Җв”Җв”Җ out[-1]в”Җв”ҳ

c = clock(freq=10)

var out = signal(10,0.0)

sum = c + out[-1]

out <- sum * 2.0

var samples = []

on out changed as evt:
  samples = samples + [evt.value]

// run the network for a while
c.run()
wait(ms=600)

var count = len(samples)
if count > 4:
  count = 4

var idx = 0
while idx < count:
  print(samples[idx], flush=true)
  idx = idx + 1

print('done')
