# ai.nn module test: load MNIST-8 and classify hand-drawn digits
import ai.nn

var model = ai.nn.Model("../modules/ai/mnist-8.onnx")

# --- metadata ---
var ins = model.inputs()
print(len(ins))
print(ins[0]["name"])
print(ins[0]["dtype"])

var outs = model.outputs()
print(len(outs))
print(outs[0]["name"])
print(model.device() == "cpu" or model.device() == "cuda")

# --- digit "1": vertical stroke in center ---
var img1 = tensor(1, 1, 28, 28, dtype='float32')
var r = 4
while r <= 23:
  img1[0, 0, r, 13] = 1.0
  img1[0, 0, r, 14] = 1.0
  r = r + 1
# small top serif
img1[0, 0, 4, 12] = 0.8
img1[0, 0, 5, 12] = 0.5
# bottom base
var c = 11
while c <= 17:
  img1[0, 0, 24, c] = 1.0
  c = c + 1

var out1 = model.predict(img1)
# argmax
var best1 = 0
var best1_score = out1[0, 0]
var i = 1
while i < 10:
  if out1[0, i] > best1_score:
    best1 = i
    best1_score = out1[0, i]
  i = i + 1
print(best1)

# --- digit "0": oval ---
var img0 = tensor(1, 1, 28, 28, dtype='float32')
c = 10
while c <= 17:
  img0[0, 0, 5, c] = 1.0
  img0[0, 0, 6, c] = 0.8
  img0[0, 0, 21, c] = 1.0
  img0[0, 0, 22, c] = 0.8
  c = c + 1
r = 6
while r <= 21:
  img0[0, 0, r, 9] = 1.0
  img0[0, 0, r, 10] = 0.8
  img0[0, 0, r, 17] = 1.0
  img0[0, 0, r, 18] = 0.8
  r = r + 1

var out0 = model.predict(img0)
var best0 = 0
var best0_score = out0[0, 0]
i = 1
while i < 10:
  if out0[0, i] > best0_score:
    best0 = i
    best0_score = out0[0, i]
  i = i + 1
print(best0)

# --- predict as standalone closure ---
var predict = model.predict
var out_p = predict(img1)
var best_p = 0
var best_p_score = out_p[0, 0]
i = 1
while i < 10:
  if out_p[0, i] > best_p_score:
    best_p = i
    best_p_score = out_p[0, i]
  i = i + 1
print(best_p)

# --- close ---
model.close()
print("done")
