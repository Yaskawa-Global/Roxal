import sys
mylib = sys.loadlib('../tests/testlib.so')

@cstruct(arch=64)
type MyStruct object:
  var i:int
  @ctype(ctype='float')
  var f:real

@cfunc(lib=mylib, cname='make_struct', args='int i,float f', ret='MyStruct')
func make_struct(i: int, f: real) -> MyStruct:
  _

var s = make_struct(5, 6.5)
print(s.i)
print(s.f)
