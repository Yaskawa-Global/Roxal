import arithematic.*
// Manual sample requiring ROXAL_ENABLE_GRPC build and a server for compiler/grpc/protos/arithematic.proto

// Types live in the imported module; import* pulls them into scope
var svc = Arithematic("127.0.0.1:50051")

// The generated stubs are exposed as Add/Subtract/etc.
var sum = svc.Add(arg1=10, arg2=7)          // flattened call
var diff = svc.Subtract(arg1=10, arg2=7)

var req = NumRequest(arg1=10, arg2=7)
var prod = svc.Multiply(request=req)        // explicit request still works
var quot = svc.Divide(request=req)

print(sum.ans)   // expected 17
print(diff.ans)  // expected 3
print(prod.ans)  // expected 70
print(quot.ans)  // expected 1
