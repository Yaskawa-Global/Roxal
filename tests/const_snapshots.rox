// Test multiple snapshots and const-to-const passthrough

type Box object:
    var value :int

// 1. Multiple snapshots at different epochs
var b = Box(1)
const c1 = b    // snapshot at value=1
b.value = 2
const c2 = b    // snapshot at value=2
b.value = 3

print(c1.value)  // 1
print(c2.value)  // 2
print(b.value)   // 3

// 2. Const-to-const passthrough (no re-snapshot)
const c3 = c1    // should reuse existing frozen clone
print(c3.value)  // 1

// 3. Snapshot of a list at different times
var l = [10, 20]
const cl1 = l
l.append(30)
const cl2 = l
l.append(40)

print(cl1)  // [10, 20]
print(cl2)  // [10, 20, 30]
print(l)    // [10, 20, 30, 40]

// 4. Clone from const returns mutable
var mutable_copy = clone(c1)
mutable_copy.value = 99
print(mutable_copy.value)  // 99
print(c1.value)            // 1 - original const unaffected
