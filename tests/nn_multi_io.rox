# ai.nn multi-input/output test
# add-sub.onnx: sum_out = a + b, diff_out = a - b, shape [1, 3]
import ai.nn

var model = ai.nn.Model("../modules/ai/add-sub.onnx")

# verify 2 inputs and 2 outputs
print(len(model.inputs()))
print(len(model.outputs()))
print(model.inputs()[0]['name'])
print(model.inputs()[1]['name'])
print(model.outputs()[0]['name'])
print(model.outputs()[1]['name'])

# prepare inputs
var a = tensor(1, 3, dtype='float32')
a[0, 0] = 10.0
a[0, 1] = 20.0
a[0, 2] = 30.0

var b = tensor(1, 3, dtype='float32')
b[0, 0] = 1.0
b[0, 1] = 2.0
b[0, 2] = 3.0

# --- dict-based multi-input ---
var results = model.predict({'a': a, 'b': b})
print(len(results))

var sum_out = results[0]
var diff_out = results[1]

print(sum_out[0, 0])
print(sum_out[0, 1])
print(sum_out[0, 2])
print(diff_out[0, 0])
print(diff_out[0, 1])
print(diff_out[0, 2])

# --- list-based multi-input ---
var results2 = model.predict([a, b])
print(results2[0][0, 0])
print(results2[1][0, 0])

# --- error: wrong number of list inputs ---
try:
  model.predict([a])
  print("ERROR: should have thrown")
except e:
  print("caught list length error")

model.close()
print("done")
