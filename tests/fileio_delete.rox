import fileio

var base = '../tests/tmp_fileio_delete'
var file_path = base + '/file.txt'
var missing_file = base + '/missing.txt'
var empty_dir = base + '/empty_dir'
var nested_dir = base + '/nested'
var nested_child = nested_dir + '/child.txt'

if fileio.dir_exists(base):
  fileio.delete_dir(base, true)

print(fileio.create_dir(base))
print(fileio.dir_exists(base))
print(fileio.create_dir(nested_dir + '/deep', true))
print(fileio.dir_exists(nested_dir))

var handle = fileio.open(file_path, true)
fileio.write(handle, 'alpha')
fileio.close(handle)

print(fileio.create_dir(file_path))

fileio.create_dir(empty_dir)
fileio.create_dir(nested_dir)

var nested_handle = fileio.open(nested_child, true)
fileio.write(nested_handle, 'child')
fileio.close(nested_handle)

print(fileio.file_exists(file_path))
print(fileio.delete_file(file_path))
print(fileio.file_exists(file_path))
print(fileio.delete_file(file_path))
print(fileio.delete_file(missing_file))

print(fileio.dir_exists(empty_dir))
print(fileio.delete_dir(empty_dir, false))
print(fileio.dir_exists(empty_dir))
print(fileio.delete_dir(empty_dir, false))

print(fileio.delete_dir(nested_dir, false))
print(fileio.dir_exists(nested_dir))
print(fileio.delete_dir(nested_dir, true))
print(fileio.dir_exists(nested_dir))
print(fileio.delete_dir(nested_dir, true))

fileio.delete_dir(base, true)
