type A actor:
  private var state = []

  func make():
    state = [0]
    return clone(state)

  func change():
    state[0] = 1
    print('actor changed')
    return true

  func snapshot():
    return clone(state)

var a = A()
var l = a.make()
print(l)
var fut = a.change()
print(fut)
print(l)
print(a.snapshot())
