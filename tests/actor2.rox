var g = false

type A actor:
  func addone(n):
    sleep(us=100000)
    g = true
    return n+1

var a = A()
var n2 = a.addone(1)
print(g) // shoud still be false since addone returns a future immediately

print(n2) // should block then auto-convert n2 to return value 2 and print 2
print(g)  // should now be true since addone completed

