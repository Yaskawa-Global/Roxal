type A actor:
  func addone(n):
    wait(us=100000)
    return n+1

var a = A()
var n2 = a.addone(1)
print(is_ready(n2)) // should be false because actor work is outstanding

var result = int(n2)
print(result) // should print 2 after waiting for the actor
print(is_ready(n2)) // future has resolved now
