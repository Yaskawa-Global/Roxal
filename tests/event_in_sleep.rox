type EventProducer actor:

  //proc printid():
  //  print('EventProducer thread id '+_threadid())

  func emitEvents():

    wait(us=100000)

    for i in range(1..2):
      print('emit '+i)
      emit E()
      wait(us=100000)



type E event
p = EventProducer()
//p.printid()

when E occurs:
  print('e occured')

p.emitEvents()

print('sleeping for .5s')
wait(us=500000)
print('awake')

print('done')
