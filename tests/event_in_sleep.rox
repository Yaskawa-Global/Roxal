
print('main thread id:'+_threadid())

type EventProducer actor:

  proc printid():
    print('EventProducer thread id '+_threadid())

  func emitEvents(e :event):

    for i in range(1..10):
      print('emit '+i)
      e.emit()
      sleep(1000000)
    


var e :event
p = EventProducer()
p.printid()

on e:
  print('e occured')

p.emitEvents(e)

print('sleeping for 10')
sleep(10000000)
print('awake')

print('done')

