var l1 = [1,2,3]
var l2 = [1,2,3]
print("l1 is l2? " + (l1 is l2)) // false

var i1 = 1
var i2 = 1
print("i1 is i2? " + (i1 is i2)) // true

var s = "hello"
print("s is string? " + (s is string))

// strings are interned
print("'str' is 'str'? "+('str' is 'str')) // true
var s1 = 'hello'
var s2 = 'hello'
var s3 = 'there'
print('s1 is s2? '+(s1 is s2)) // true
print('s1 is s3? '+(s1 is s3)) // false
 
var v1 = [1 2 3]
var v2 = [1 2 3]
var v3 = v1
print("v1 is v2? " + (v1 is v2)) // false
print("v1 is v3? " + (v1 is v3)) // true

var m1 = [1 2;3 4]
var m2 = [1 2;3 4]
var m3 = m1
print("m1 is m2? " + (m1 is m2)) // false
print("m1 is m3? " + (m1 is m3)) // true
print("m3 is matrix? " + (m3 is matrix)) // true

