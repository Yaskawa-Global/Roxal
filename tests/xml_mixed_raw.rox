var xml = '<p>hello <b>robot</b> world</p>'
var doc = from_xml(xml, 'raw')
print(doc.tag)
print(len(doc.children))
print('[' + doc.children[0] + ']')
print(doc.children[1].tag)
print(doc.children[1].children[0])
