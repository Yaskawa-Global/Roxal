var s = "glad to meet you"
print("Hi, I'm {s}")

s2 = "."

print("{s}{s2}") // 'glad to meet you.'

print('{s}') // {s}

type Item object:
   var name
   proc init(n):
     this.name = n

type Box object:
   var label
   var items
   proc init(label, items):
     this.label = label
     this.items = items
   func describe(index):
     return "Box {this.label} has {this.items[index].name}"

var box = Box("letters", [Item("alpha"), Item("beta"), Item("gamma")])
var idx = 2
var col = 1

print("label={box.label}")
print("first item={box.items[0].name}")
print(box.describe(1))
print("chosen={box.items[idx].name}")
print("literal index={box.items[2].name}")
print("from method={box.describe(0)}")
var metadata = { 'owner': 'clerk', 'tags': { 'primary': 'letters' } }
var mat = matrix([[1, 2, 3], [4, 5, 6]])
var row = 1

print("dict lookup={metadata['tags']['primary']}")
print("matrix direct={mat[1, 0]}")
print("matrix vars={mat[row, col]}")
