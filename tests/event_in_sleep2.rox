
print('main thread id:'+_threadid())

type EventConsumer actor:

  proc printid():
    print('EventConsumer thread id '+_threadid())

  func handleEvents(e :event):

    on e:
      print('event e occured')

    print('handleEvents sleeping for 10s')
    sleep(10000000)
    print('handleEvents exiting')    


var e :event
p = EventConsumer()
p.printid()
p.handleEvents(e)

for i in range(1..10):
  print('emit '+i)
  e.emit()
  sleep(1000000)

print('done')
