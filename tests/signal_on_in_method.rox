
const Freq = 2

type Button object:

  var clicked :signal = signal(Freq,false)

  func onClicked(callback) -> Button:
    on clicked changed:
      callback(this)
    return this

  func clickTest():
    clicked.set(true)


func handleClicked(button):
  print("button clicked now="+button.clicked)

b = Button()
b.onClicked(handleClicked)

b.clickTest()

wait(ms=200)
