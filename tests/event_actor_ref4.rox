
var e :event

type MyActor actor:

  proc setup():
    on e:
      print('e handled in MyActor')


type MyOtherActor actor:

  proc setup():
    on e:
      sleep(us=20000) // avoid colliding prints
      print('e handled in MyOtherActor')


  


a = MyActor()
oa = MyOtherActor()

a.setup()
oa.setup()

sleep(us=10000)

emit e // should trigger both handlers

sleep(us=1000)

a = nil
oa = nil

sleep(us=10000)

emit e // should trigger none

