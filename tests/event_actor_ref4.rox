
type E event

type MyActor actor:

  proc setup():
    on E:
      print('e handled in MyActor')


type MyOtherActor actor:

  proc setup():
    on E:
      wait(us=20000) // avoid colliding prints
      print('e handled in MyOtherActor')


  


a = MyActor()
oa = MyOtherActor()

a.setup()
oa.setup()

wait(us=10000)

emit E() // should trigger both handlers

wait(us=1000)

a = nil
oa = nil

wait(us=10000)

emit E() // should trigger none

